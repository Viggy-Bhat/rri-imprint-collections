# Core environment
DJANGO_SETTINGS_MODULE=backend.settings.production
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=change-me-to-a-long-random-value

# Networking
DJANGO_ALLOWED_HOSTS=example.com,www.example.com
DJANGO_CORS_ALLOWED_ORIGINS=https://app.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.example.com

# Database and cache
DATABASE_URL=postgres://postgres:postgres@db:5432/rri_imprint
DATABASE_SSL_REQUIRE=0
REDIS_URL=redis://redis:6379/1
DJANGO_DB_CONN_MAX_AGE=60
DJANGO_CACHE_TIMEOUT=300

# Security
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_SECURE_HSTS_PRELOAD=1
DJANGO_SECURE_PROXY_SSL_HEADER_NAME=HTTP_X_FORWARDED_PROTO
DJANGO_SECURE_PROXY_SSL_HEADER_VALUE=https

# Upload limits
DJANGO_DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
DJANGO_FILE_UPLOAD_MAX_MEMORY_SIZE=10485760

# Logging
DJANGO_LOG_LEVEL=INFO

# Wagtail
WAGTAILADMIN_BASE_URL=https://app.example.com
